def save_sleep_modes_to_csv(base_params: ModelParams, filename="/user/sleep_modes.csv"):
    variants = [0, 5, 10, 20, 40, 80]

    with open(filename, "w", newline="", encoding="utf-8") as file:
        writer = csv.writer(file)
        writer.writerow([
            "T_sleep",
            "loss_probability",
            "adaptive_reject_probability",
            "buffer_loss_probability",
            "avg_response_time",
            "energy",
            "wakeup_count",
            "score"
        ])

        for i, t_sleep in enumerate(variants):
            params = ModelParams(**base_params.__dict__)
            params.t_sleep = t_sleep
            params.seed = base_params.seed + i * 100

            result, _ = run_replications(params)

            writer.writerow([
                t_sleep,
                result["loss_probability"],
                result["adaptive_reject_probability"],
                result["buffer_loss_probability"],
                result["avg_response_time"],
                result["energy"],
                result["wakeup_count"],
                result["score"]
            ])


